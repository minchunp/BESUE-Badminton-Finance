# ================================================================
# Server Environment Variables — BESUE Badminton Finance
# ================================================================
# QUAN TRỌNG: File này KHÔNG được commit lên GitHub!
# Xem .env.example để biết cấu trúc cần thiết.
# ================================================================

# ── Server ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=5001

# ── Database ────────────────────────────────────────────────────
# Development: MongoDB local
# Production:  MongoDB Atlas URI (mongodb+srv://...)
MONGODB_URI=mongodb://localhost:27017/besue_badminton_finance

# ── JWT Authentication ───────────────────────────────────────────
# PHẢI thay bằng chuỗi ngẫu nhiên dài ít nhất 64 ký tự trên Production!
# Tạo nhanh: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=besue_dev_secret_change_me_on_production
JWT_EXPIRES_IN=30d

# ── CORS ────────────────────────────────────────────────────────
# Development: origin của Vite dev server
# Production:  URL của Vercel frontend (không có trailing slash)
CLIENT_ORIGIN=http://localhost:5173